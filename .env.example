# Copy this file to .env and adjust as needed.
# JWT_SECRET is auto-generated into .env on first run if you don't set one.

NODE_ENV=production

# Set to true only if this app is served over HTTPS (directly or behind a
# reverse proxy like Caddy/nginx). Leave false for a plain-HTTP LAN deployment,
# otherwise the login cookie won't be sent and sign-in will silently fail.
COOKIE_SECURE=false

# Only used the very first time the app starts (when the users sheet is empty).
# Change the password after your first sign-in either way.
DEFAULT_ADMIN_PASSWORD=admin123

# Google Sheets database configuration.
# Create a Sheet with tabs named "users" and "items" and paste the spreadsheet ID here.
GOOGLE_SHEETS_ID=

# For Google service account auth, set one of these:
# GOOGLE_APPLICATION_CREDENTIALS=./service-account.json
# or
# GOOGLE_SERVICE_ACCOUNT_CREDENTIALS='{"type":"service_account", ... }'

# ---- Magic-link login + email reports (Gmail SMTP) ----
# Use a Gmail / Google Workspace account with an App Password
# (Google Account → Security → 2-Step Verification → App passwords).
SMTP_USER=you@attune-integrations.com
SMTP_PASS=16bit password
# From address (defaults to SMTP_USER if omitted)
SMTP_FROM=Stockroom <you@attune-integrations.com>
# Public base URL of the app — used to build magic-link URLs in emails.
# Must match how users reach the app (e.g. https://stockroom.yourcompany.com)
PORT=5174
APP_URL=http://localhost:5174